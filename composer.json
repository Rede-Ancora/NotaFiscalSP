{
    "name": "redeancora/notafiscalsp",
    "description": "Integração com o WebService da Prefeitura de São Paulo para emissão de NFS e NTFS utilizando a API da nota do milhão",
    "type": "library",
    "license": "MIT",
    "replace": {
        "greenter/xmldsig": "5.0.3"
    },
    "require": {
        "php": "^8.0",
        "robrichards/xmlseclibs": "^3.0",
        "spatie/array-to-xml": "^3.3",
        "ext-dom": "*",
        "ext-soap": "*"
    },
    "suggest": {
        "ext-mbstring": "*"
    },
    "keywords": [
        "NFS",
        "NFTS",
        "Emissão Nota Fiscal",
        "Nota Fiscal",
        "Nota do Milhão",
        "Prefeitura São Paulo",
        "Nota Fiscal Tomador de Serviços"
    ],
    "authors": [
        {
            "name": "Kaio Valdemar",
            "email": "profkaio@outlook.com"
        },
        {
            "name": "Marcelo Mendonça da Silva (marceloms163)"
        }
    ],
    "autoload": {
        "psr-4": {
            "NotaFiscalSP\\": "src/",
            "Greenter\\XMLSecLibs\\": "lib/Greenter/XMLSecLibs/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": ">=7.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable"
}
